# Idempotency store
# Uncomment both values to enable Redis-backed idempotency (required for multi-replica deployments).
# Without it, an in-process dict is used (dev / single-instance only).
#export IRI_IDEMPOTENCY_STORE=app.demo_adapter.RedisIdempotencyStore
#export REDIS_URL=redis://localhost:6379
#export IDEMPOTENCY_TTL_SECONDS=86400   # how long a successful response is cached (default: 24h)
#export LOCK_TTL_SECONDS=60             # max in-flight lock lifetime before auto-expiry (default: 60s)

# S3DF adapter wiring. Storage remains hidden until S3DFStorageAdapter exists.
export IRI_API_ADAPTER_account=app.s3df.account_adapter.S3DFAccountAdapter
export IRI_API_ADAPTER_compute=app.s3df.compute_adapter.SLACComputeAdapter
export IRI_API_ADAPTER_facility=app.s3df.facility_adapter.S3DFFacilityAdapter
export IRI_API_ADAPTER_filesystem=app.s3df.filesystem_adapter.S3DFFilesystemAdapter
export IRI_API_ADAPTER_status=app.s3df.status_adapter.S3DFStatusAdapter
export IRI_API_ADAPTER_task=app.s3df.task_adapter.S3DFTaskAdapter
export IRI_SHOW_MISSING_ROUTES=false

# Facility identity. Keep this stable because status resources reference it.
export S3DF_FACILITY_NAME=s3df

# Dex JWT verification
export DEX_JWKS_URL=https://dex.slac.stanford.edu/keys
export DEX_ISSUER=https://dex.slac.stanford.edu
export DEX_AUDIENCE=
export DEX_USERNAME_CLAIM=name

# CoAct and POSIX user lookup
export COACT_API_URL=https://coact.slac.stanford.edu/graphql-service
export COACT_SERVICE_USER=
export COACT_SERVICE_PASSWORD=
export COACT_AUTH_HEADER=coactimp
export USER_LOOKUP_URL=

# Slurm REST API. The legacy lowercase slurm_jwt variable is also accepted.
export SLURM_REST_URL=
export SLURM_JWT=
export SLURM_JWT_LIFETIME=3600
export SLURM_VERIFY_SSL=false
export SLURM_DEFAULT_PARTITION=
export SLURM_DEFAULT_ACCOUNT=

# Filesystem facade
export FS_FACADE_URL=http://fs-facade-service:8100
export FS_FACADE_POLL_INTERVAL=0.25
export FS_FACADE_TIMEOUT=60

# globus app credentials
export GLOBUS_APP_ID=<your dev app's id goes here>
export GLOBUS_APP_SECRET=<your dev app's secret goes here>

# the resource server's credentials
export GLOBUS_RS_ID=ed3e577d-f7f3-4639-b96e-ff5a8445d699
export GLOBUS_RS_SECRET=<the resource server's secret goes here - ask Gabor to add you to the resource server>

export GLOBUS_RS_SCOPE_SUFFIX=iri_api

# S3DF status adapter
export S3DF_STATUS_API_URL=http://s3df-status-api:8080
export S3DF_STATUS_API_TIMEOUT=10
export S3DF_STATUS_REQUIRE_FULL_COVERAGE=true
export S3DF_STATUS_CHECKS_FILE=
export S3DF_STATUS_CHECKS_JSON='{}'
